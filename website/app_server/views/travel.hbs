{{!-- Travel page rendered using Handlebars --}}
{{!-- Data is provided by the travel controller following MVC principles --}}

{{> header}}

<h1 class="page-title">{{title}}</h1>

{{!-- Search and action controls (UI only for this module) --}}
<section class="actions">
  <input class="input" type="text" placeholder="Search Travel" />
  <button class="button" type="button">Add a Trip</button>
</section>

{{!-- Category tabs --}}
<section>
  <h2>Categories</h2>
  <ul class="tabs">
    {{#each categories}}
      <li class="tab">
        <a
          href="/travel?category={{this}}"
          class="tab-link {{#if (isEqual this ../selectedCategory)}}active{{/if}}"
        >
          {{this}} ({{lookup ../tripCounts this}})
        </a>
      </li>
    {{/each}}
  </ul>

  <p class="muted"><strong>Showing:</strong> {{selectedCategory}}</p>
</section>

{{!-- Trip data table --}}
<section>
  <h2>Trips</h2>

  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Length</th>
        <th>Start</th>
        <th>Resort</th>
        <th>Per Person</th>
      </tr>
    </thead>

    <tbody>
      {{#each trips}}
        <tr>
          <td>{{id}}</td>
          <td>{{name}}</td>
          <td>{{length}}</td>
          <td>{{start}}</td>
          <td>{{resort}}</td>
          <td>{{perPerson}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>

{{> footer}}