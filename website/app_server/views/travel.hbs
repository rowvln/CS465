{{!--
  Travel Page
  This view dynamically renders trip data passed from the controller.
  Trip information is sourced from trips.json and injected using Handlebars.
--}}

<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>Dive Sites - Bhaccasyoniztas Beach Resort Website Template</title>

	{{!-- Load shared stylesheet from public directory --}}
	<link rel="stylesheet" href="/css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{!-- Shared navigation header partial --}}
			{{> header}}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>Travel</h1>

							{{!--
              				Loop through trips array provided by the controller.
              				Each trip object represents a destination from trips.json.
            				--}}
							<ul id="sites">
								{{#each trips}}
								<li>
									<a href="/travel"><img src="/images/{{this.image}}" alt="Img"></a>
									<h2><a href="/travel">{{this.name}}</a></h2>
									{{{this.description}}}
								</li>
								{{/each}}
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
		{{!-- Shared footer partial --}}
		{{> footer}}
	</div>
</body>
</html>